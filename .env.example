# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Redis (Upstash or self-hosted) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── API ────────────────────────────────────────────────────────────────────
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
API_SECRET=change-me-random-64-char-string

# ─── Music Generation ───────────────────────────────────────────────────────
# Provider: suno | udio | musicgen | mock
GENERATION_PROVIDER=mock
SUNO_API_KEY=
UDIO_API_KEY=

# ─── Storage ────────────────────────────────────────────────────────────────
# Uses Supabase Storage by default (no extra config needed)
# Override for external S3:
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_BUCKET_AUDIO=audio
# STORAGE_BUCKET_ARTWORK=artwork

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── PostHog ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
